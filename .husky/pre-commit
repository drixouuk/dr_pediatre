if git diff --cached --name-only | grep -q "apps/cms/src/collections/"; then
  MIGRATION_ADDED=$(git diff --cached --name-only | grep "apps/cms/src/migrations/" | grep -v "index.ts")
  if [ -z "$MIGRATION_ADDED" ]; then
    echo "⚠️  Modification détectée dans apps/cms/src/collections/ sans nouvelle migration."
    echo "   Lance 'npx payload migrate:create' avant de commit, ou force avec --no-verify."
    exit 1
  fi
fi

if git diff --cached --name-only | grep -q "\.env\.example$"; then
  STAGED_SECRETS=$(git diff --cached -- ".env.example" | grep -E '^\+.*(DATABASE_URI=|_SECRET=|_KEY=)' | grep -v 'XXXXX' | grep -E '.{21,}$')
  if [ -n "$STAGED_SECRETS" ]; then
    echo "⚠️  Valeur non-placeholder détectée dans .env.example"
    echo "   Remplace par XXXXX avant de commit, ou force avec --no-verify si c'est un faux positif volontaire."
    echo "$STAGED_SECRETS"
    exit 1
  fi
fi


