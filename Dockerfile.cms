FROM node:22-alpine AS base
RUN corepack enable && corepack prepare pnpm@9.15.0 --activate
WORKDIR /app

FROM base AS deps
COPY pnpm-lock.yaml pnpm-workspace.yaml package.json ./
COPY apps/cms/package.json apps/cms/
COPY apps/frontend/package.json apps/frontend/
RUN pnpm install --frozen-lockfile

FROM base AS builder
COPY --from=deps /app/node_modules ./node_modules
COPY --from=deps /app/apps/cms/node_modules ./apps/cms/node_modules
COPY --from=deps /app/apps/frontend/node_modules ./apps/frontend/node_modules
COPY apps/ apps/
COPY package.json pnpm-lock.yaml ./
RUN pnpm --filter drpediatre-cms build

FROM base AS runner
COPY --from=deps /app/node_modules /app/node_modules
COPY --from=deps /app/apps/cms/node_modules /app/apps/cms/node_modules
COPY --from=builder /app/apps/cms/.next /app/apps/cms/.next
COPY --from=builder /app/apps/cms/next.config.ts /app/apps/cms/
COPY --from=builder /app/apps/cms/public /app/apps/cms/public
COPY --from=builder /app/apps/cms/package.json /app/apps/cms/
COPY --from=builder /app/apps/cms/dist /app/apps/cms/dist
COPY package.json pnpm-workspace.yaml /app/
ENV NODE_ENV=production
EXPOSE 3000
CMD ["pnpm", "--filter", "drpediatre-cms", "start"]
